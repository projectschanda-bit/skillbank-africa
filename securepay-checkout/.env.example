# Server Config
PORT=5000
NODE_ENV=development

# Lenco API (BroadPay)
# Get these from: https://dashboard.lenco.co/developers/api-keys
LENCO_SECRET_KEY=YOUR_LENCO_SECRET_KEY
LENCO_PUBLIC_KEY=YOUR_LENCO_PUBLIC_KEY
LENCO_WEBHOOK_URL=https://your-vercel-domain.vercel.app/api/webhooks/lenco
LENCO_BASE_URL=https://api.lenco.co/access/v2

# Firebase Config
# Path to your firebase-service-account.json file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_STORAGE_BUCKET=skillbank-africa.appspot.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5500