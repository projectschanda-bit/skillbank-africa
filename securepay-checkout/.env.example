# Server Config
PORT=3000
NODE_ENV=development

# Lenco API (BroadPay)
# Get these from: https://dashboard.lenco.co/developers/api-keys
LENCO_SECRET_KEY=sk_test_...
LENCO_PUBLIC_KEY=pk_test_...
LENCO_WEBHOOK_URL=https://your-domain.com/api/webhook/lenco
LENCO_BASE_URL=https://api.lenco.co/access/v2

# Firebase Config
# Path to your firebase-service-account.json file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_STORAGE_BUCKET=skillbank-africa.appspot.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5500
